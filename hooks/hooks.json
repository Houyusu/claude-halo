{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -File \"${CLAUDE_PLUGIN_ROOT}/scripts/halo-hook.ps1\" -State idle"
          },
          {
            "type": "command",
            "command": "powershell -Command \"Start-Process '${CLAUDE_PLUGIN_ROOT}/bin/claude-halo.exe'\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -File \"${CLAUDE_PLUGIN_ROOT}/scripts/halo-hook.ps1\" -State thinking"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion|ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -File \"${CLAUDE_PLUGIN_ROOT}/scripts/halo-hook.ps1\" -State input_needed"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -File \"${CLAUDE_PLUGIN_ROOT}/scripts/halo-hook.ps1\" -State executing"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -File \"${CLAUDE_PLUGIN_ROOT}/scripts/halo-hook.ps1\" -State completed"
          },
          {
            "type": "command",
            "command": "powershell -Command \"Remove-Item $env:TEMP\\claude-halo-heartbeat.txt -Force -ErrorAction SilentlyContinue\""
          },
          {
            "type": "command",
            "command": "powershell -Command \"exit 0\""
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -File \"${CLAUDE_PLUGIN_ROOT}/scripts/halo-hook.ps1\" -State compacting"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -File \"${CLAUDE_PLUGIN_ROOT}/scripts/halo-hook.ps1\" -State idle"
          }
        ]
      }
    ]
  }
}
